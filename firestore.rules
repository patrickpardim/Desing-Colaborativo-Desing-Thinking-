rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    // Rooms collection
    match /rooms/{pin} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;

      // Subcollection: Ideas
      match /ideas/{ideaId} {
        allow read: if true;
        allow create, update, delete: if true;
      }

      // Subcollection: Participants
      match /participants/{participantId} {
        allow read: if true;
        allow create, update, delete: if true;
      }

      // Subcollection: Columns
      match /columns/{columnId} {
        allow read: if true;
        allow create, update, delete: if true;
      }
    }

    // Admin logins and credentials
    match /admin_logins/{loginId} {
      allow read, create, update, delete: if true;
    }

    match /admin_credentials/{docId} {
      allow read, create, update: if true;
    }
  }
}
